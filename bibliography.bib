  urldate = {2026-06-11},
  abstract = {Large language models offer new opportunities for behavioural science, but their rapid evolution poses challenges for research rigour. We introduce a consensus-based reporting checklist to improve transparency, reproducibility and ethical accountability of large-language-model-based research in the behavioural sciences.},
